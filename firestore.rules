rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;
      // Owner can do anything to their own profile
      allow write: if request.auth != null && request.auth.uid == uid;
      // Another user may update only the friends field when:
      //   (a) accepting a request — there's a pending friendRequest from uid to them, or
      //   (b) removing a friend — uid already lists them as a friend
      allow update: if request.auth != null
        && request.auth.uid != uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends'])
        && (
          exists(/databases/$(database)/documents/friendRequests/$(request.auth.uid)/incoming/$(uid))
          || resource.data.get('friends', []).hasAll([request.auth.uid])
        );
    }

    match /days/{uid}/entries/{date} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        get(/databases/$(database)/documents/users/$(uid)).data.get('friends', []).hasAny([request.auth.uid])
      );
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /customTasks/{uid}/tasks/{taskId} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        (
          get(/databases/$(database)/documents/users/$(uid)).data.get('friends', []).hasAny([request.auth.uid]) &&
          resource.data.get('visible', true) == true
        )
      );
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /nudges/{nudgeId} {
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid;
      // Doc is deleted by Cloud Function immediately after processing — no client reads needed
      allow read: if false;
    }

    match /users/{uid}/nudgeCooldowns/{cooldownId} {
      allow read, write: if false; // written by Cloud Functions admin SDK only
    }

    match /friendRequests/{toUid}/incoming/{fromUid} {
      // Anyone logged in can send a request (write where fromUid == their own uid)
      allow create: if request.auth != null && request.auth.uid == fromUid;
      // Only the recipient can read, delete (decline), or the sender can delete (cancel)
      allow read: if request.auth != null && request.auth.uid == toUid;
      allow delete: if request.auth != null &&
        (request.auth.uid == toUid || request.auth.uid == fromUid);
      // Recipient can mark as accepted (triggers Cloud Function notification to sender)
      allow update: if request.auth != null && request.auth.uid == toUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }
  }
}
