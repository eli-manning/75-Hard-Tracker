rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;
      // Owner can do anything to their own profile
      allow write: if request.auth != null && request.auth.uid == uid;
      // Another user may update only the friends field when:
      //   (a) accepting a request — there's a pending friendRequest from uid to them, or
      //   (b) removing a friend — uid already lists them as a friend
      allow update: if request.auth != null
        && request.auth.uid != uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends'])
        && (
          exists(/databases/$(database)/documents/friendRequests/$(request.auth.uid)/incoming/$(uid))
          || resource.data.get('friends', []).hasAll([request.auth.uid])
        );
    }

    match /days/{uid}/entries/{date} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        get(/databases/$(database)/documents/users/$(uid)).data.get('friends', []).hasAny([request.auth.uid])
      );
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /customTasks/{uid}/tasks/{taskId} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        (
          get(/databases/$(database)/documents/users/$(uid)).data.get('friends', []).hasAny([request.auth.uid]) &&
          resource.data.get('visible', true) == true
        )
      );
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /nudges/{nudgeId} {
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid;
      // Doc is deleted by Cloud Function immediately after processing — no client reads needed
      allow read: if false;
    }

    match /users/{uid}/nudgeCooldowns/{cooldownId} {
      allow read, write: if false; // written by Cloud Functions admin SDK only
    }

    match /friendRequests/{toUid}/incoming/{fromUid} {
      // Anyone logged in can send a request (write where fromUid == their own uid)
      allow create: if request.auth != null && request.auth.uid == fromUid;
      // Only the recipient can read, delete (decline), or the sender can delete (cancel)
      allow read: if request.auth != null && request.auth.uid == toUid;
      allow delete: if request.auth != null &&
        (request.auth.uid == toUid || request.auth.uid == fromUid);
      // Recipient can mark as accepted (triggers Cloud Function notification to sender)
      allow update: if request.auth != null && request.auth.uid == toUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    match /crews/{crewId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.members;

      allow create: if request.auth != null
        && request.resource.data.creatorUid == request.auth.uid
        && request.auth.uid in request.resource.data.members
        && request.auth.uid in request.resource.data.admins
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 30
        && request.resource.data.joinCode is string
        && request.resource.data.joinCode.size() == 6
        && request.resource.data.members.size() == 1
        && request.resource.data.crewStreak == 0
        && request.resource.data.longestCrewStreak == 0;

      allow update: if request.auth != null
        && request.auth.uid in resource.data.members
        // Immutable fields — nobody can change these from the client
        && request.resource.data.crewStreak == resource.data.crewStreak
        && request.resource.data.longestCrewStreak == resource.data.longestCrewStreak
        && request.resource.data.members == resource.data.members
        && request.resource.data.joinCode == resource.data.joinCode
        && request.resource.data.creatorUid == resource.data.creatorUid
        && (
          // Any member: update customCrewTasks only (admins array must not change)
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['customCrewTasks'])
            && request.resource.data.admins == resource.data.admins)
          ||
          // Admins: update name/icon/activeTasks/customCrewTasks (admins array must not change)
          (request.auth.uid in resource.data.admins
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['name', 'icon', 'activeTasks', 'customCrewTasks'])
            && request.resource.data.admins == resource.data.admins)
          ||
          // Creator only: promote/demote admins — creator must remain in admins
          (request.auth.uid == resource.data.creatorUid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['admins'])
            && resource.data.creatorUid in request.resource.data.admins)
        );

      allow delete: if request.auth != null
        && request.auth.uid == resource.data.creatorUid;
    }

    match /crews/{crewId}/summaries/{date} {
      allow read: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/crews/$(crewId)).data.members;
      allow write: if false;
    }
  }
}
