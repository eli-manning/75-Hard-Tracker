# Copy this file to .env.local and fill in your values.
# See README.md for instructions on setting up your Firebase project.

# ── Firebase ──────────────────────────────────────────────────────────────────
# Found in Firebase Console → Project Settings → Your apps → SDK setup
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Found in Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
EXPO_PUBLIC_FIREBASE_VAPID_KEY=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Found in Google Cloud Console → APIs & Services → Credentials
# Web client ID (used for OAuth on web)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# iOS client ID (used for native Google Sign-In on iOS)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# ── Optional: Developer accounts ─────────────────────────────────────────────
# Accounts that get custom avatar image files instead of DiceBear avatars.
# Format: comma-separated "email:/avatars/filename.png" pairs.
# Leave blank to use DiceBear for all users.
EXPO_PUBLIC_CUSTOM_AVATAR_MAP=

# Comma-separated emails that skip DiceBear seed generation on sign-up.
# Should match the emails in EXPO_PUBLIC_CUSTOM_AVATAR_MAP.
EXPO_PUBLIC_CUSTOM_AVATAR_EMAILS=

# UID that enables the rocket/space visual theme easter egg. Leave blank to disable.
EXPO_PUBLIC_ROCKET_UID=
